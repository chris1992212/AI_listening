.container { padding: 40rpx; }
.title { font-size: 40rpx; font-weight: bold; margin-bottom: 48rpx; }
.form .label { font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.form .input, .form .picker { border: 1rpx solid #ddd; padding: 24rpx; border-radius: 12rpx; margin-bottom: 32rpx; }
.picker { color: #333; }
.btn { margin-top: 48rpx; background: #07c160; color: #fff; border-radius: 12rpx; }
.btn-assistant { margin-top: 24rpx; background: #1565c0; }
