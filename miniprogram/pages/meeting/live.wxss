.container { padding: 32rpx; min-height: 100vh; box-sizing: border-box; }
.topic { font-size: 28rpx; color: #666; margin-bottom: 32rpx; }
.lamp-wrap { text-align: center; margin: 48rpx 0; }
.mode-tip { background: #eef6ff; color: #1565c0; padding: 16rpx; border-radius: 10rpx; margin-bottom: 20rpx; font-size: 24rpx; }
.lamp { width: 160rpx; height: 160rpx; border-radius: 50%; margin: 0 auto 24rpx; }
.lamp.gray { background: #e0e0e0; }
.lamp.yellow { background: #ffc107; }
.lamp.green { background: #07c160; }
.lamp-label { font-size: 30rpx; color: #333; }
.advice { background: #f5f5f5; padding: 24rpx; border-radius: 12rpx; margin-bottom: 24rpx; }
.advice-label { font-size: 24rpx; color: #888; display: block; margin-bottom: 8rpx; }
.advice-text { font-size: 30rpx; color: #333; }
.reason { font-size: 24rpx; color: #999; margin-bottom: 24rpx; }
.error { font-size: 24rpx; color: #c62828; margin-bottom: 16rpx; }
.hint { font-size: 24rpx; color: #1565c0; margin-bottom: 16rpx; line-height: 1.5; }
.meta { background: #fafafa; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.meta-title { font-size: 26rpx; color: #333; margin-bottom: 10rpx; }
.meta-text { font-size: 28rpx; color: #444; }
.asr { border: 1rpx dashed #ddd; border-radius: 12rpx; padding: 16rpx; margin-bottom: 24rpx; }
.asr-title { font-size: 24rpx; color: #888; margin-bottom: 12rpx; }
.asr-line { font-size: 26rpx; color: #444; margin-bottom: 8rpx; }
.recent { height: 280rpx; border: 1rpx solid #eee; border-radius: 12rpx; padding: 16rpx; }
.recent-title { font-size: 24rpx; color: #888; margin-bottom: 12rpx; }
.line { font-size: 26rpx; color: #555; margin-bottom: 8rpx; }
.btn-end { margin-top: 48rpx; color: #666; background: #f0f0f0; border-radius: 12rpx; }
